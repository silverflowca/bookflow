# BookFlow Client - Environment Configuration
# ============================================================
# For Railway: Set these as build arguments in the Dockerfile
# For local dev: Copy this file to .env and fill in values
# ============================================================

# Supabase URL (same as server SUPABASE_URL)
# Used for building public file URLs (cover images, media)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API URL (for production, use /api as it's served from same domain)
VITE_API_URL=/api
