# BookFlow Server - Environment Configuration
# ============================================================
# For Railway: Set these as environment variables in the service settings
# For local dev: Copy this file to .env and fill in your values
# ============================================================

# Server Configuration
PORT=8682
NODE_ENV=production

# ============================================================
# SUPABASE CLOUD SETUP (Required)
# ============================================================
# 1. Go to https://supabase.com and create a project (or use existing)
# 2. Go to Project Settings > API
# 3. Copy the values below:

# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key (Settings > API > service_role key) - KEEP SECRET!
# This key bypasses Row Level Security - never expose to client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon/Public Key (Settings > API > anon public key)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# CLIENT CONFIGURATION
# ============================================================

# Client URL for CORS (your Railway client domain or custom domain)
CLIENT_URL=https://bookflow-client.up.railway.app

# ============================================================
# INTEGRATIONS
# ============================================================

# FileFlow Integration (your deployed FileFlow URL)
FILEFLOW_URL=https://fileflow.up.railway.app

# ChangeFlow Integration (optional)
CHANGEFLOW_URL=https://changeflow.up.railway.app

# ============================================================
# SECURITY
# ============================================================

# JWT Secret for auth tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-a-strong-32-char-secret-here

# ============================================================
# DEEPGRAM TTS (Text-to-Speech)
# ============================================================

# Deepgram API Key for TTS functionality
DEEPGRAM_API_KEY=your-deepgram-api-key
